cat > .env.example << 'EOF'
# Copy this file to `.env` on the server and fill in real values.
# NEVER commit the real .env to git.

# Generate a real one with:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# False in production. True only for local dev.
DJANGO_DEBUG=False

# Comma-separated. Put your EC2 public DNS, domain, and/or DuckDNS here.
DJANGO_ALLOWED_HOSTS=your-ec2-public-dns.compute.amazonaws.com,yourname.duckdns.org

# Only needed if you use HTTPS. Include scheme, no trailing slash.
DJANGO_CSRF_TRUSTED_ORIGINS=https://yourname.duckdns.org

# Set to False while testing HTTP only; True once certbot is configured.
DJANGO_SECURE_SSL_REDIRECT=False

DJANGO_TIME_ZONE=Asia/Kolkata
DJANGO_LOG_LEVEL=INFO

# --- Database ---
# Leave empty to use SQLite (fine for the college demo).
# For Postgres on the same EC2 host:
#   DATABASE_URL=postgres://churn_user:strong_password@127.0.0.1:5432/churn_db
# For RDS:
#   DATABASE_URL=postgres://churn_user:strong_password@your-rds-endpoint.rds.amazonaws.com:5432/churn_db
#   DJANGO_DB_SSLMODE=require
DATABASE_URL=
DJANGO_DB_SSLMODE=prefer
EOF