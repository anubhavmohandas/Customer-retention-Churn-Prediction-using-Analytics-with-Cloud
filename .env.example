# ============================================================
# LOCAL DEVELOPMENT  (copy this file to .env and edit)
# ============================================================
# Quick start for running locally:
#
#   cp .env.example .env
#   # then just change DJANGO_SECRET_KEY to anything random
#   python -m venv myvenv && source myvenv/bin/activate   (Windows: myvenv\Scripts\activate)
#   pip install -r requirements.txt
#   python manage.py migrate
#   python manage.py createsuperuser
#   python manage.py runserver
#   open http://127.0.0.1:8000
#
# Generate a real secret key:
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
# ============================================================

# ---- REQUIRED: change this to any random string locally ----
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string

# ---- Set True for local dev, False in production ----
DJANGO_DEBUG=True

# ---- Local dev defaults (no changes needed) ----
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# ---- SSL: must be False for local HTTP ----
DJANGO_SECURE_SSL_REDIRECT=False

# ---- HSTS: irrelevant locally, leave as-is ----
DJANGO_HSTS_SECONDS=0

DJANGO_TIME_ZONE=Asia/Kolkata
DJANGO_LOG_LEVEL=DEBUG

# ---- Database ----
# Leave empty to use SQLite (perfect for local dev).
# No postgres needed locally.
DATABASE_URL=
DJANGO_DB_SSLMODE=prefer


# ============================================================
# PRODUCTION OVERRIDES  (EC2 / server only)
# ============================================================
# DJANGO_DEBUG=False
# DJANGO_ALLOWED_HOSTS=your-ec2-public-dns.compute.amazonaws.com,yourname.duckdns.org
# DJANGO_CSRF_TRUSTED_ORIGINS=https://yourname.duckdns.org
# DJANGO_SECURE_SSL_REDIRECT=True
# DJANGO_HSTS_SECONDS=31536000
# DATABASE_URL=postgres://churn_user:strong_password@127.0.0.1:5432/churn_db
